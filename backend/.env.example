# =============================
# JENGU PAYMENTS BACKEND CONFIG
# =============================

# EXPRESS SERVER
PORT=8080

# CORS & SECURITY
# Which frontend origin is allowed to call this API
# Use specific domain in production, not "*"
FRONTEND_ORIGIN=http://localhost:5500

# PAYMENT PROVIDER: CINETPAY
PAYMENT_PROVIDER=cinetpay

# CinetPay API Credentials
# Get these from your CinetPay merchant dashboard
PAYMENT_API_KEY=replace_me_with_actual_api_key
PAYMENT_SITE_ID=replace_me_with_site_id

# Webhook Configuration
# IMPORTANT: Set these to your actual domain in production
PAYMENT_NOTIFY_URL=http://localhost:8080/api/payments/webhooks/cinetpay
PAYMENT_RETURN_URL=http://localhost:5500/checkout-success.html

# Webhook Security
# Secret used to verify webhook signatures from CinetPay
# Must match the webhook secret configured in CinetPay dashboard
PAYMENT_WEBHOOK_SECRET=replace_me_with_webhook_secret

# =============================
# OPTIONAL: EMAIL CONFIGURATION
# (For future email confirmations)
# =============================
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your_key_here

# =============================
# LOGGING
# =============================
# Logs are stored in backend/logs/ directory
# No configuration needed unless you want to send to external service

# =============================
# CRITICAL NOTES
# =============================
# 1. PAYMENT_WEBHOOK_SECRET must match CinetPay webhook configuration
# 2. PAYMENT_NOTIFY_URL must be publicly accessible for webhooks
# 3. Use HTTPS in production (not http://)
# 4. Keep secrets in .env file, never commit to version control

